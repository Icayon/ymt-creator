<Window x:Class="YMTCreator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="YMT Creador — GTA V  |  by @ivancayonh"
        Height="750" Width="1180" MinHeight="550" MinWidth="800"
        Background="#1a1a1a" Foreground="#e0e0e0"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>
        <!-- ── Colors ──────────────────────────────────────────────────────── -->
        <SolidColorBrush x:Key="Bg0"      Color="#1a1a1a"/>
        <SolidColorBrush x:Key="Bg1"      Color="#242424"/>
        <SolidColorBrush x:Key="Bg2"      Color="#2d2d2d"/>
        <SolidColorBrush x:Key="Border"   Color="#3a3a3a"/>
        <SolidColorBrush x:Key="Accent"   Color="#F7B731"/>
        <SolidColorBrush x:Key="AccentDk" Color="#c9931f"/>
        <SolidColorBrush x:Key="TextMain" Color="#e8e8e8"/>
        <SolidColorBrush x:Key="TextSub"  Color="#888888"/>
        <SolidColorBrush x:Key="Green"    Color="#27ae60"/>
        <SolidColorBrush x:Key="Red"      Color="#e74c3c"/>

        <!-- ── Button style ─────────────────────────────────────────────────── -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"   Value="{StaticResource Accent}"/>
            <Setter Property="Foreground"   Value="#1a1a1a"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Padding"      Value="14,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentDk}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#555"/>
                                <Setter Property="Foreground" Value="#888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnSecondary" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Background" Value="{StaticResource Bg2}"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3d3d3d"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Language button style ────────────────────────────────────────── -->
        <Style x:Key="LangBtn" TargetType="Button">
            <Setter Property="Width"          Value="30"/>
            <Setter Property="Height"         Value="22"/>
            <Setter Property="FontSize"       Value="11"/>
            <Setter Property="FontWeight"     Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"         Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── TextBox style ────────────────────────────────────────────────── -->
        <Style x:Key="TxtDark" TargetType="TextBox">
            <Setter Property="Background"        Value="{StaticResource Bg2}"/>
            <Setter Property="Foreground"        Value="{StaticResource TextMain}"/>
            <Setter Property="BorderBrush"       Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="Padding"           Value="6,4"/>
            <Setter Property="CaretBrush"        Value="{StaticResource Accent}"/>
            <Setter Property="SelectionBrush"    Value="{StaticResource AccentDk}"/>
        </Style>

        <!-- ── TreeView / TreeViewItem styles ──────────────────────────────── -->
        <Style TargetType="TreeView">
            <Setter Property="Background"    Value="{StaticResource Bg0}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"       Value="4"/>
        </Style>

        <Style TargetType="TreeViewItem">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Foreground"       Value="{StaticResource TextMain}"/>
            <Setter Property="Padding"          Value="3,2"/>
            <Setter Property="IsExpanded"       Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <Border x:Name="ItemBorder" Background="Transparent"
                                    BorderThickness="0" CornerRadius="3"
                                    Margin="0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Expand toggle -->
                                    <ToggleButton x:Name="Expander"
                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                  ClickMode="Press"
                                                  Width="16" Height="16"
                                                  Focusable="False"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Cursor="Hand">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent">
                                                    <Path x:Name="Arrow"
                                                          Data="M 4 6 L 12 6 L 8 11 Z"
                                                          Fill="#666" Stretch="None"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Arrow" Property="Data"
                                                                Value="M 4 6 L 12 6 L 8 11 Z"/>
                                                    </Trigger>
                                                    <Trigger Property="IsChecked" Value="False">
                                                        <Setter TargetName="Arrow" Property="Data"
                                                                Value="M 6 4 L 11 8 L 6 12 Z"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <!-- Header -->
                                    <ContentPresenter x:Name="PART_Header"
                                                      Grid.Column="1"
                                                      ContentSource="Header"
                                                      VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <!-- Children -->
                            <ItemsPresenter x:Name="ItemsHost"
                                            Margin="16,0,0,0"
                                            Visibility="Collapsed"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#2a2a2a"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#222"/>
                            </Trigger>
                            <!-- Hide expander when no children -->
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Checkbox style ───────────────────────────────────────────────── -->
        <Style x:Key="ChkDark" TargetType="CheckBox">
            <Setter Property="Foreground"  Value="{StaticResource TextMain}"/>
            <Setter Property="Margin"      Value="0,0,4,0"/>
        </Style>

        <!-- ── ScrollBar ────────────────────────────────────────────────────── -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#1a1a1a"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="46"/>   <!-- Header -->
            <RowDefinition Height="52"/>   <!-- Toolbar -->
            <RowDefinition Height="*"/>    <!-- Content -->
            <RowDefinition Height="30"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- HEADER                                                              -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource Accent}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtHeaderTitle"
                           Text="■  YMT CREADOR — GTA V PED CLOTHING"
                           FontWeight="Bold" FontSize="15"
                           Foreground="#1a1a1a"
                           VerticalAlignment="Center" Margin="16,0"/>
                <TextBlock x:Name="TxtHeaderSub"
                           Grid.Column="1"
                           Text="Genera el .ymt para peds addon de GTA V"
                           Foreground="#55290000"
                           FontSize="11" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <!-- Language toggle -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,12,0">
                    <Button x:Name="BtnLangEs" Content="ES"
                            Style="{StaticResource LangBtn}"
                            Click="BtnLangEs_Click"/>
                    <Button x:Name="BtnLangEn" Content="EN"
                            Style="{StaticResource LangBtn}"
                            Margin="3,0,0,0"
                            Click="BtnLangEn_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- TOOLBAR                                                             -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="{StaticResource Bg1}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="TxtFolderLabel"
                           Grid.Column="0" Text="Carpeta:" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSub}" Margin="0,0,8,0"/>
                <TextBox   Grid.Column="1" x:Name="TxtFolder"
                           Style="{StaticResource TxtDark}"
                           VerticalAlignment="Center" IsReadOnly="True"
                           Text="(selecciona una carpeta con .ydd y .ytd)"/>
                <Button    Grid.Column="2" x:Name="BtnBrowse"
                           Content="📁  Abrir carpeta"
                           Style="{StaticResource BtnSecondary}"
                           VerticalAlignment="Center" Margin="8,0,0,0"
                           Click="BtnBrowse_Click"/>
                <Button    Grid.Column="3" Content="⟳  Escanear"
                           Style="{StaticResource BtnPrimary}"
                           x:Name="BtnScan"
                           VerticalAlignment="Center" Margin="6,0,0,0"
                           IsEnabled="False"
                           Click="BtnScan_Click"/>

                <TextBlock x:Name="TxtDlcLabel"
                           Grid.Column="5" Text="DLC name:" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSub}" Margin="0,0,8,0"/>
                <TextBox   Grid.Column="6" x:Name="TxtDlcName"
                           Style="{StaticResource TxtDark}"
                           Width="160" VerticalAlignment="Center"
                           ToolTip="Valor del campo &lt;dlcName&gt; (puede dejarse vacío)"/>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- MAIN CONTENT                                                        -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" MinWidth="200"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT: Ped tree ──────────────────────────────────────────── -->
            <Grid Grid.Column="0" Background="{StaticResource Bg1}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Tree header -->
                <Border Grid.Row="0" Background="{StaticResource Bg2}"
                        BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
                        Padding="10,7">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="TxtTreeHeader"
                                   Text="PRENDAS DETECTADAS"
                                   FontWeight="SemiBold" FontSize="11"
                                   Foreground="{StaticResource Accent}"
                                   VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="BtnExpandAll"
                                    Content="+" Style="{StaticResource BtnSecondary}"
                                    FontSize="15" Padding="6,2" Margin="0,0,4,0"
                                    ToolTip="Expandir todo" Click="BtnExpandAll_Click"/>
                            <Button x:Name="BtnCollapseAll"
                                    Content="−" Style="{StaticResource BtnSecondary}"
                                    FontSize="15" Padding="6,2"
                                    ToolTip="Colapsar todo" Click="BtnCollapseAll_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- TreeView -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                    <TreeView x:Name="PedTree" Margin="4"/>
                </ScrollViewer>
            </Grid>

            <!-- ── Splitter ────────────────────────────────────────────────── -->
            <GridSplitter Grid.Column="1" Width="5"
                          Background="{StaticResource Border}"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

            <!-- ── RIGHT: XML preview + actions ──────────────────────────────── -->
            <Grid Grid.Column="2" Background="{StaticResource Bg0}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- XML toolbar -->
                <Border Grid.Row="0" Background="{StaticResource Bg2}"
                        BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
                        Padding="10,7">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="TxtXmlHeader"
                                   Text="PREVISUALIZACIÓN XML  (listo para CodeWalker)"
                                   FontWeight="SemiBold" FontSize="11"
                                   Foreground="{StaticResource Accent}"
                                   VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="BtnGenerate"
                                    Content="⚙  Generar YMT.XML"
                                    Style="{StaticResource BtnPrimary}"
                                    IsEnabled="False" Margin="0,0,6,0"
                                    Click="BtnGenerate_Click"/>
                            <Button x:Name="BtnSave"
                                    Content="💾  Guardar"
                                    Style="{StaticResource BtnSecondary}"
                                    IsEnabled="False" Margin="0,0,6,0"
                                    Click="BtnSave_Click"/>
                            <Button x:Name="BtnCopy"
                                    Content="📋  Copiar"
                                    Style="{StaticResource BtnSecondary}"
                                    Click="BtnCopy_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- XML text area -->
                <TextBox Grid.Row="1" x:Name="TxtXml"
                         Style="{StaticResource TxtDark}"
                         FontFamily="Consolas" FontSize="12"
                         BorderThickness="0"
                         IsReadOnly="True"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap"
                         AcceptsReturn="True"
                         Background="#121212"
                         Foreground="#c8d3e0"
                         Padding="12"/>
            </Grid>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- STATUS BAR                                                          -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="{StaticResource Bg2}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtStatus"
                           Text="Listo. Selecciona una carpeta para comenzar."
                           Foreground="{StaticResource TextSub}"
                           VerticalAlignment="Center" FontSize="12"/>
                <TextBlock x:Name="TxtStats"
                           Grid.Column="1"
                           Foreground="{StaticResource TextSub}"
                           VerticalAlignment="Center" FontSize="12"/>
            </Grid>
        </Border>
    </Grid>
</Window>
