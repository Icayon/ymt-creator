<Window x:Class="YMTCreator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="YMT Creador — GTA V  |  by @ivancayonh"
        Height="750" Width="1180" MinHeight="580" MinWidth="860"
        Background="#1a1a1a" Foreground="#e0e0e0"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>
        <SolidColorBrush x:Key="Bg0"      Color="#1a1a1a"/>
        <SolidColorBrush x:Key="Bg1"      Color="#242424"/>
        <SolidColorBrush x:Key="Bg2"      Color="#2d2d2d"/>
        <SolidColorBrush x:Key="Border"   Color="#3a3a3a"/>
        <SolidColorBrush x:Key="Accent"   Color="#F7B731"/>
        <SolidColorBrush x:Key="AccentDk" Color="#c9931f"/>
        <SolidColorBrush x:Key="TextMain" Color="#e8e8e8"/>
        <SolidColorBrush x:Key="TextSub"  Color="#888888"/>

        <!-- ── Button styles ────────────────────────────────────────────────── -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource Accent}"/>
            <Setter Property="Foreground"      Value="#1a1a1a"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="14,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentDk}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#555"/>
                                <Setter Property="Foreground" Value="#888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnSecondary" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Background" Value="{StaticResource Bg2}"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3d3d3d"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LangBtn" TargetType="Button">
            <Setter Property="Width"           Value="30"/>
            <Setter Property="Height"          Value="22"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── TextBox style ────────────────────────────────────────────────── -->
        <Style x:Key="TxtDark" TargetType="TextBox">
            <Setter Property="Background"      Value="{StaticResource Bg2}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextMain}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="6,4"/>
            <Setter Property="CaretBrush"      Value="{StaticResource Accent}"/>
            <Setter Property="SelectionBrush"  Value="{StaticResource AccentDk}"/>
        </Style>

        <!-- ── TabControl / TabItem styles ─────────────────────────────────── -->
        <Style TargetType="TabControl">
            <Setter Property="Background"      Value="{StaticResource Bg0}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="{StaticResource Bg1}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSub}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Padding"    Value="18,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush"
                                        Value="{StaticResource Accent}"/>
                                <Setter TargetName="TabBorder" Property="Background"
                                        Value="{StaticResource Bg2}"/>
                                <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background"
                                        Value="#2a2a2a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── TreeView / TreeViewItem styles ──────────────────────────────── -->
        <Style TargetType="TreeView">
            <Setter Property="Background"      Value="{StaticResource Bg0}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="4"/>
        </Style>

        <Style TargetType="TreeViewItem">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Foreground"  Value="{StaticResource TextMain}"/>
            <Setter Property="Padding"     Value="3,2"/>
            <Setter Property="IsExpanded"  Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <Border x:Name="ItemBorder" Background="Transparent"
                                    BorderThickness="0" CornerRadius="3" Margin="0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton x:Name="Expander"
                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                  ClickMode="Press" Width="16" Height="16"
                                                  Focusable="False" Background="Transparent"
                                                  BorderThickness="0" Cursor="Hand">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent">
                                                    <Path x:Name="Arrow" Data="M 4 6 L 12 6 L 8 11 Z"
                                                          Fill="#666" Stretch="None"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Arrow" Property="Data"
                                                                Value="M 4 6 L 12 6 L 8 11 Z"/>
                                                    </Trigger>
                                                    <Trigger Property="IsChecked" Value="False">
                                                        <Setter TargetName="Arrow" Property="Data"
                                                                Value="M 6 4 L 11 8 L 6 12 Z"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <ContentPresenter x:Name="PART_Header" Grid.Column="1"
                                                      ContentSource="Header" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <ItemsPresenter x:Name="ItemsHost" Margin="16,0,0,0" Visibility="Collapsed"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#2a2a2a"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#222"/>
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── DataGrid style ───────────────────────────────────────────────── -->
        <Style x:Key="DarkGrid" TargetType="DataGrid">
            <Setter Property="Background"             Value="#1e1e1e"/>
            <Setter Property="Foreground"             Value="{StaticResource TextMain}"/>
            <Setter Property="BorderBrush"            Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness"        Value="1"/>
            <Setter Property="RowBackground"          Value="#242424"/>
            <Setter Property="AlternatingRowBackground" Value="#1e1e1e"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2a2a2a"/>
            <Setter Property="VerticalGridLinesBrush"   Value="#2a2a2a"/>
            <Setter Property="SelectionMode"          Value="Single"/>
            <Setter Property="IsReadOnly"             Value="True"/>
            <Setter Property="AutoGenerateColumns"    Value="False"/>
            <Setter Property="HeadersVisibility"      Value="Column"/>
            <Setter Property="CanUserResizeRows"      Value="False"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background"      Value="{StaticResource Bg2}"/>
                        <Setter Property="Foreground"      Value="{StaticResource Accent}"/>
                        <Setter Property="FontWeight"      Value="SemiBold"/>
                        <Setter Property="Padding"         Value="10,6"/>
                        <Setter Property="BorderBrush"     Value="{StaticResource Border}"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="FontSize"        Value="11"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding"         Value="10,4"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Foreground"      Value="{StaticResource TextMain}"/>
                        <Setter Property="FontFamily"      Value="Consolas"/>
                        <Setter Property="FontSize"        Value="12"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#1e3a5f"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#1a1a1a"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="46"/>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource Accent}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtHeaderTitle"
                           Text="■  YMT CREADOR — GTA V PED CLOTHING"
                           FontWeight="Bold" FontSize="15" Foreground="#1a1a1a"
                           VerticalAlignment="Center" Margin="16,0"/>
                <TextBlock x:Name="TxtHeaderSub" Grid.Column="1"
                           Text="Genera el .ymt para peds addon de GTA V"
                           Foreground="#55290000" FontSize="11"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,12,0">
                    <Button x:Name="BtnLangEs" Content="ES" Style="{StaticResource LangBtn}"
                            Click="BtnLangEs_Click"/>
                    <Button x:Name="BtnLangEn" Content="EN" Style="{StaticResource LangBtn}"
                            Margin="3,0,0,0" Click="BtnLangEn_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ TOOLBAR ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="{StaticResource Bg1}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtFolderLabel" Grid.Column="0" Text="Carpeta:"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextSub}" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" x:Name="TxtFolder" Style="{StaticResource TxtDark}"
                         VerticalAlignment="Center" IsReadOnly="True"
                         Text="(selecciona una carpeta con .ydd y .ytd)"/>
                <Button Grid.Column="2" x:Name="BtnBrowse" Content="📁  Abrir carpeta"
                        Style="{StaticResource BtnSecondary}"
                        VerticalAlignment="Center" Margin="8,0,0,0"
                        Click="BtnBrowse_Click"/>
                <Button Grid.Column="3" x:Name="BtnScan" Content="⟳  Escanear"
                        Style="{StaticResource BtnPrimary}"
                        VerticalAlignment="Center" Margin="6,0,0,0"
                        IsEnabled="False" Click="BtnScan_Click"/>
                <TextBlock x:Name="TxtDlcLabel" Grid.Column="5" Text="DLC name:"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextSub}" Margin="0,0,8,0"/>
                <TextBox Grid.Column="6" x:Name="TxtDlcName" Style="{StaticResource TxtDark}"
                         Width="160" VerticalAlignment="Center"
                         ToolTip="Valor del campo &lt;dlcName&gt; (puede dejarse vacío)"/>
            </Grid>
        </Border>

        <!-- ═══ TAB CONTENT ═══════════════════════════════════════════════════ -->
        <TabControl x:Name="MainTabs" Grid.Row="2">

            <!-- ── Tab 1: YMT Generator ─────────────────────────────────────── -->
            <TabItem x:Name="TabGen">
                <TabItem.Header>
                    <TextBlock x:Name="TxtTabGen" Text="Generador YMT" FontSize="12" FontWeight="SemiBold"/>
                </TabItem.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="340" MinWidth="200"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: tree -->
                    <Grid Grid.Column="0" Background="{StaticResource Bg1}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{StaticResource Bg2}"
                                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
                                Padding="10,7">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="TxtTreeHeader" Text="PRENDAS DETECTADAS"
                                           FontWeight="SemiBold" FontSize="11"
                                           Foreground="{StaticResource Accent}"
                                           VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button x:Name="BtnExpandAll" Content="+"
                                            Style="{StaticResource BtnSecondary}"
                                            FontSize="15" Padding="6,2" Margin="0,0,4,0"
                                            ToolTip="Expandir todo" Click="BtnExpandAll_Click"/>
                                    <Button x:Name="BtnCollapseAll" Content="−"
                                            Style="{StaticResource BtnSecondary}"
                                            FontSize="15" Padding="6,2"
                                            ToolTip="Colapsar todo" Click="BtnCollapseAll_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto">
                            <TreeView x:Name="PedTree" Margin="4"/>
                        </ScrollViewer>
                    </Grid>

                    <GridSplitter Grid.Column="1" Width="5"
                                  Background="{StaticResource Border}"
                                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

                    <!-- Right: XML preview -->
                    <Grid Grid.Column="2" Background="{StaticResource Bg0}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{StaticResource Bg2}"
                                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
                                Padding="10,7">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="TxtXmlHeader"
                                           Text="PREVISUALIZACIÓN XML  (listo para CodeWalker)"
                                           FontWeight="SemiBold" FontSize="11"
                                           Foreground="{StaticResource Accent}"
                                           VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button x:Name="BtnGenerate" Content="⚙  Generar YMT.XML"
                                            Style="{StaticResource BtnPrimary}"
                                            IsEnabled="False" Margin="0,0,6,0"
                                            Click="BtnGenerate_Click"/>
                                    <Button x:Name="BtnSave" Content="💾  Guardar"
                                            Style="{StaticResource BtnSecondary}"
                                            IsEnabled="False" Margin="0,0,6,0"
                                            Click="BtnSave_Click"/>
                                    <Button x:Name="BtnCopy" Content="📋  Copiar"
                                            Style="{StaticResource BtnSecondary}"
                                            Click="BtnCopy_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <TextBox Grid.Row="1" x:Name="TxtXml" Style="{StaticResource TxtDark}"
                                 FontFamily="Consolas" FontSize="12" BorderThickness="0"
                                 IsReadOnly="True"
                                 HorizontalScrollBarVisibility="Auto"
                                 VerticalScrollBarVisibility="Auto"
                                 TextWrapping="NoWrap" AcceptsReturn="True"
                                 Background="#121212" Foreground="#c8d3e0" Padding="12"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ── Tab 2: File Organizer ─────────────────────────────────────── -->
            <TabItem x:Name="TabOrg">
                <TabItem.Header>
                    <TextBlock x:Name="TxtTabOrg" Text="Organizador" FontSize="12" FontWeight="SemiBold"/>
                </TabItem.Header>
                <Grid Background="{StaticResource Bg0}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Info banner -->
                        <RowDefinition Height="Auto"/>  <!-- Ped name + output -->
                        <RowDefinition Height="*"/>     <!-- DataGrid -->
                        <RowDefinition Height="Auto"/>  <!-- Buttons -->
                        <RowDefinition Height="30"/>    <!-- Org status -->
                    </Grid.RowDefinitions>

                    <!-- Info banner -->
                    <Border Grid.Row="0" Background="#1e2a1e"
                            BorderBrush="#2a4a2a" BorderThickness="0,0,0,1" Padding="14,8">
                        <TextBlock x:Name="TxtOrgInfo"
                                   TextWrapping="Wrap" FontSize="12"
                                   Foreground="#88bb88"
                                   Text="Escanea una carpeta con ropa de distintos packs. La herramienta empareja cada drawable con sus texturas y los renumera secuencialmente. Introduce el nombre de la ped, selecciona la carpeta destino y pulsa Copiar y renombrar."/>
                    </Border>

                    <!-- Ped name + output folder -->
                    <Border Grid.Row="1" Background="{StaticResource Bg1}"
                            BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
                            Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="TxtOrgPedLabel" Grid.Column="0"
                                       Text="Nombre de la ped:"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSub}" Margin="0,0,8,0"/>
                            <TextBox x:Name="TxtOrgPedName" Grid.Column="1"
                                     Style="{StaticResource TxtDark}"
                                     VerticalAlignment="Center"
                                     ToolTip="Nombre base de la nueva ped (ej. mynewped)"/>
                            <!-- spacer -->
                            <TextBlock x:Name="TxtOrgOutputLabel" Grid.Column="3"
                                       Text="Carpeta destino:"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSub}" Margin="0,0,8,0"/>
                            <TextBox x:Name="TxtOrgOutputFolder" Grid.Column="4"
                                     Style="{StaticResource TxtDark}"
                                     VerticalAlignment="Center" IsReadOnly="True"/>
                            <Button x:Name="BtnOrgBrowse" Grid.Column="5"
                                    Content="📁  Seleccionar"
                                    Style="{StaticResource BtnSecondary}"
                                    VerticalAlignment="Center"
                                    Click="BtnOrgBrowse_Click"/>
                            <Button x:Name="BtnOrgPreview" Grid.Column="7"
                                    Content="🔍  Vista previa"
                                    Style="{StaticResource BtnSecondary}"
                                    VerticalAlignment="Center"
                                    Click="BtnOrgPreview_Click"/>
                        </Grid>
                    </Border>

                    <!-- File mapping DataGrid -->
                    <DataGrid x:Name="OrgGrid" Grid.Row="2"
                              Style="{StaticResource DarkGrid}"
                              Margin="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn x:Name="ColOldName"
                                                Header="Archivo original"
                                                Binding="{Binding OldName}"
                                                Width="*"/>
                            <DataGridTextColumn Header="→"
                                                IsReadOnly="True"
                                                Width="28">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#555"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn x:Name="ColNewName"
                                                Header="Nuevo nombre"
                                                Binding="{Binding NewName}"
                                                Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#aaddff"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Action buttons -->
                    <Border Grid.Row="3" Background="{StaticResource Bg1}"
                            BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0"
                            Padding="12,8">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="BtnOrgCopy"
                                    Content="📋  Copiar y renombrar"
                                    Style="{StaticResource BtnPrimary}"
                                    IsEnabled="False" Margin="0,0,8,0"
                                    Click="BtnOrgCopy_Click"/>
                            <Button x:Name="BtnOrgGenerateYmt"
                                    Content="⚙  Generar YMT"
                                    Style="{StaticResource BtnSecondary}"
                                    IsEnabled="False"
                                    Click="BtnOrgGenerateYmt_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Organizer status -->
                    <Border Grid.Row="4" Background="{StaticResource Bg2}"
                            BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
                        <TextBlock x:Name="TxtOrgStatus"
                                   Text="Escanea una carpeta primero (usa la barra de herramientas)."
                                   Foreground="{StaticResource TextSub}"
                                   VerticalAlignment="Center" FontSize="12" Margin="12,0"/>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- ═══ STATUS BAR ════════════════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="{StaticResource Bg2}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtStatus"
                           Text="Listo. Selecciona una carpeta para comenzar."
                           Foreground="{StaticResource TextSub}"
                           VerticalAlignment="Center" FontSize="12"/>
                <TextBlock x:Name="TxtStats" Grid.Column="1"
                           Foreground="{StaticResource TextSub}"
                           VerticalAlignment="Center" FontSize="12"/>
            </Grid>
        </Border>
    </Grid>
</Window>
